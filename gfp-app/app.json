{
  "expo": {
    "name": "GetFitPlans",
    "slug": "getfitplans",
    "version": "1.3.0",
    "scheme": "getfitplans",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#14181C",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14181C"
    },
    "android": {
      "package": "com.getfitplans.companion",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#14181C"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "GetFitPlans uses the camera to log meals by photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
